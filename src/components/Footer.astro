---
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="py-8 border-t border-slate-200 dark:border-slate-700">
  <div
    class="container mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <p class="text-sm text-slate-500">&copy; {year} Thanh Tu Vo. Built with Astro.</p>
    <SocialLinks iconSize="w-5 h-5" />
    <a href="#hero" class="text-sm text-slate-500 hover:text-primary-500 transition-colors">
      Back to top
    </a>
  </div>
</footer>
