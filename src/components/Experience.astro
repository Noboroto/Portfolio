---
import profile from '../data/profile.json';
---

{profile.experience && profile.experience.length > 0 && (
  <section id="experience" class="py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-2xl sm:text-3xl font-bold mb-8 text-center">Volunteer Work</h2>
      <div class="space-y-6">
        {
          profile.experience.map((exp) => (
            <div class="p-3 sm:p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50">
              <div class="flex gap-3 sm:gap-4 items-start">
                <div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 bg-slate-200 dark:bg-slate-700 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h4 class="font-semibold text-lg">{exp.organization}</h4>
                  <p class="text-sm text-slate-500 dark:text-slate-500 mb-2">{exp.location}</p>
                  <div class="space-y-3 border-l-2 border-slate-200 dark:border-slate-700 pl-4">
                    {exp.roles.map((role) => (
                      <div>
                        <p class="font-medium">{role.title} <span class="text-sm text-slate-500">· {role.type}</span></p>
                        <p class="text-sm text-slate-500 dark:text-slate-500">{role.startDate} – {role.endDate}</p>
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">{role.description}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
)}
